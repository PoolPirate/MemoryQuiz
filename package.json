{
  "name": "memoryquiz",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop memory games powered by Google Photos Takeout exports.",
  "author": "OpenCode",
  "type": "module",
  "main": "dist-electron/main/electron-main.js",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron-build,electron \"npm:dev:renderer\" \"npm:dev:electron:build\" \"npm:dev:electron\"",
    "dev:renderer": "vite dev --host 127.0.0.1 --port 5173",
    "dev:electron:build": "esbuild src/main/electron-main.ts src/preload/index.ts --bundle --platform=node --format=cjs --outdir=dist-electron --packages=external --external:electron --watch",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main/electron-main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "npm run check",
    "test": "vitest run",
    "build:renderer": "vite build",
    "build:electron": "esbuild src/main/electron-main.ts src/preload/index.ts --bundle --platform=node --format=cjs --outdir=dist-electron --packages=external --external:electron",
    "build": "npm run build:renderer && npm run build:electron",
    "package": "npm run build && electron-builder --publish never",
    "package:win": "npm run build && electron-builder --publish never --win nsis portable"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "exifr": "^7.1.3",
    "mime-types": "^2.1.35",
    "sharp": "^0.33.5",
    "svelte": "^5.38.6",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.26.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.15.30",
    "@types/unzipper": "^0.10.11",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.2",
    "svelte-check": "^4.1.6",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.7",
    "vitest": "^3.1.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.memoryquiz.desktop",
    "productName": "MemoryQuiz",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
